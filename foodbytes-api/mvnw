#!/bin/sh
# Maven Wrapper Downloader Script
# This downloads and runs Maven

set -e

MVN_VERSION="3.9.6"
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-$MVN_VERSION"
MAVEN_URL="https://dlcdn.apache.org/maven/maven-3/$MVN_VERSION/binaries/apache-maven-$MVN_VERSION-bin.tar.gz"

if [ ! -f "$MAVEN_HOME/bin/mvn" ]; then
    echo "Downloading Maven $MVN_VERSION..."
    mkdir -p "$MAVEN_HOME"
    curl -fsSL "$MAVEN_URL" | tar xzf - -C "$MAVEN_HOME" --strip-components=1
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
