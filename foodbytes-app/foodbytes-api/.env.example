# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=foodbytes
DB_USERNAME=root
DB_PASSWORD=password

# OAuth2 Configuration - Google
GOOGLE_CLIENT_ID=your-google-client-id-from-console
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 Configuration - GitHub
GITHUB_CLIENT_ID=your-github-client-id-from-settings
GITHUB_CLIENT_SECRET=your-github-client-secret

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-256-bit-key-for-production-use-minimum-32-characters
JWT_EXPIRATION=86400000
JWT_COOKIE_NAME=foodbytes_token

# CORS Configuration (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081

# Server Configuration
SERVER_PORT=8080

# Logging
LOG_LEVEL=DEBUG
SECURITY_LOG_LEVEL=DEBUG
SHOW_SQL=false
